rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -- Lapis 0: Safety Net --
    match /{document=**} {
      allow read, write: if false;
    }

    // -- Lapis 1: Global Helpers --
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getExistingUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getExistingUser().isAdmin == true;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // -- Lapis 2: Domain Rules --

    // Koleksi Armada (Cars)
    match /cars/{carId} {
      allow read: if true;
      
      function isValidCar(data) {
        return data.name is string && data.name.size() > 0 &&
               data.category in ['5 Seater', '7 Seater'] &&
               data.price is number &&
               data.transmission in ['AT', 'MT'] &&
               data.status in ['tersedia', 'disewa', 'perbaikan'];
      }
      
      allow create, update: if isAdmin() && isValidCar(request.resource.data);
      allow delete: if isAdmin();
    }

    // Koleksi Reservasi (Bookings)
    match /bookings/{bookingId} {
      function isValidBooking(data) {
        return data.carId is string && 
               data.userId == request.auth.uid &&
               data.status in ['menunggu', 'dikonfirmasi', 'selesai', 'dibatalkan'];
      }

      allow create: if isSignedIn() && isValidBooking(request.resource.data);
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow update: if isAdmin() || (
        isSignedIn() && 
        resource.data.userId == request.auth.uid && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['paymentProof', 'status'])
      );
      
      allow delete: if isAdmin();
    }

    // Koleksi Pengguna (Users)
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isOwner(userId) && 
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']);
      allow delete: if isAdmin();
    }
  }
}
